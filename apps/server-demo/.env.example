# MCP server demo – copy to .env and set values. Env vars override config.json.
# Load with: export $(grep -v '^#' .env | xargs)  (or use a dotenv loader in the app)

# OAuth2 client_credentials auth (recommended for Workday APIs)
# MCP_AUTH_TYPE=oauthClientCredentials
# MCP_AUTH_TOKEN_URL=https://auth.example.com/oauth/token
# MCP_AUTH_CLIENT_ID=your-client-id
# MCP_AUTH_CLIENT_SECRET=your-client-secret
# MCP_AUTH_SCOPE=openid profile
# MCP_AUTH_AUDIENCE=optional-audience

# Workday tenant/base URL. If baseUrl is unset and tenantId is set, baseUrl is derived as .../ccx/api/v1/{tenantId}
# MCP_WORKDAY_TENANT_ID=mytenant
# MCP_WORKDAY_BASE_URL=https://wd2-impl-services1.workday.com/ccx/api/v1/mytenant
