# MCP server demo – copy to .env and set values. Env vars override config.json.
# Load with: export $(grep -v '^#' .env | xargs)  (or use a dotenv loader in the app)

# Transport: "stdio" | "http" (default: http)
# MCP_TRANSPORT=http

# Log level: "debug" | "info" | "warn" | "error"
# LOG_LEVEL=info

# HTTP server (when transport is http)
# PORT=8787
# HOST=127.0.0.1

# Auth: when set, enables apiKey auth and overrides config.json auth.apiKey (keep secrets out of config)
# MCP_AUTH_API_KEY=your-workday-api-key

# Workday tenant ID: when set, overrides config; baseUrl is derived as .../ccx/api/v1/{tenantId} if baseUrl not set
# MCP_WORKDAY_TENANT_ID=mytenant

# Workday base URL (API base): when set, overrides config and skips derivation from workday.tenantId
# MCP_WORKDAY_BASE_URL=https://wd2-impl-services1.workday.com/ccx/api/v1/mytenant
